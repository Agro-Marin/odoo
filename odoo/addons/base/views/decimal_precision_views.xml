<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_decimal_precision_form" model="ir.ui.view">
        <field name="name">Decimal Precision</field>
        <field name="model">decimal.precision</field>
        <field name="arch" type="xml">
            <form string="Decimal Precision">
                <sheet>
                    <group col="4">
                        <field name="name" readonly="id" />
                        <field name="digits" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_decimal_precision_tree" model="ir.ui.view">
        <field name="name">Decimal Precision List</field>
        <field name="model">decimal.precision</field>
        <field name="arch" type="xml">
            <list string="Decimal Precision">
                <field name="name" />
                <field name="digits" />
            </list>
        </field>
    </record>

    <record id="action_decimal_precision_form" model="ir.actions.act_window">
        <field name="name">Decimal Accuracy</field>
        <field name="res_model">decimal.precision</field>
    </record>

</odoo>