<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_work_entry_type_view_form_inherit" model="ir.ui.view">
        <field name="name">hr.work.entry.type.form.inherit</field>
        <field name="model">hr.work.entry.type</field>
        <field name="inherit_id" ref="hr_holidays.hr_work_entry_type_view_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='configuration']//field[@name='support_document']" position="after">
                <field name="l10n_in_is_sandwich_leave" invisible="country_code != 'IN'"/>
                <field name="l10n_in_sandwich_policy" class="w-75" invisible="country_code != 'IN' or not l10n_in_is_sandwich_leave"/>
                <field name="l10n_in_is_limited_to_optional_days" invisible="country_code != 'IN'"/>
            </xpath>
        </field>
    </record>

</odoo>
