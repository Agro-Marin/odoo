<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="True">

    <!-- Create draft refund for invoice 1 -->
    <record id="demo_refund_invoice_1" model="account.move.reversal" context="{'allowed_company_ids': [ref('base.demo_company_uy')]}">
        <field name="reason">Venta Cancelada</field>
        <field name="move_ids" eval="[Command.link(ref('account.%s_demo_invoice_1' % ref('base.demo_company_uy')))]"/>
        <field name="journal_id" model="account.journal" eval="obj().env.ref('account.%s_demo_invoice_1' % ref('base.demo_company_uy')).journal_id"/>
        <field name="date" eval="time.strftime('%Y-%m')+'-01'"/>
    </record>

    <function model="account.move.reversal" name="refund_moves" eval="[ref('demo_refund_invoice_1')]"/>

