<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view for workflow actions (used in automation form Actions tab) -->
    <record id="view_ir_actions_server_tree_workflow" model="ir.ui.view">
        <field name="name">ir.actions.server.tree.workflow</field>
        <field name="model">ir.actions.server</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <list string="Workflow Actions">
                <field name="sequence" widget="handle" />
                <field name="name" />
                <field name="state" string="Type" optional="hide" />
                <field name="predecessor_ids" widget="many2many_tags" optional="show" />
                <field name="successor_ids" widget="many2many_tags" optional="hide" />
            </list>
        </field>
    </record>

    <!-- Automation shortcut button on server action form -->
    <record id="view_server_action_form" model="ir.ui.view">
        <field name="name">Server Actions</field>
        <field name="model">ir.actions.server</field>
        <field name="inherit_id" ref="base.view_server_action_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_open_automation"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-bolt"
                    invisible="not base_automation_id"
                >
                    <div class="o_stat_info">
                        <span class="o_stat_text">Automation</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

    <!-- Dependencies page on server action form (DAG topology only, no runtime state) -->
    <record id="view_ir_actions_server_form_workflow_dag" model="ir.ui.view">
        <field name="name">ir.actions.server.form.workflow.dag</field>
        <field name="model">ir.actions.server</field>
        <field name="inherit_id" ref="base.view_server_action_form" />
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">
                <page string="Dependencies"
                    name="dependencies"
                    invisible="usage != 'base_automation' or not base_automation_id"
                    groups="base.group_user">

                    <group>
                        <group string="Dependency Info">
                            <label for="predecessor_ids" />
                            <div>
                                <field name="predecessor_ids"
                                    widget="many2many_tags"
                                    domain="[('base_automation_id', '=', base_automation_id), ('id', '!=', id)]"
                                    options="{'no_create': True}" />
                                <div class="text-muted small mt-1">
                                    <i class="fa-solid fa-info-circle" />
                                    This action executes after all predecessors complete.
                                </div>
                            </div>

                            <label for="successor_ids" />
                            <div>
                                <field name="successor_ids"
                                    widget="many2many_tags"
                                    readonly="1" />
                                <div class="text-muted small mt-1">
                                    <i class="fa-solid fa-info-circle" />
                                    These actions are unblocked when this one completes.
                                </div>
                            </div>
                        </group>
                    </group>

                    <separator string="How Dependencies Work" class="mt-4" />
                    <div class="alert alert-info" role="alert">
                        <ul class="mb-0">
                            <li><strong>No predecessors:</strong> Action starts immediately (root action)</li>
                            <li><strong>One predecessor:</strong> Waits for that action to complete</li>
                            <li><strong>Multiple predecessors:</strong> Waits for ALL to complete (AND join)</li>
                            <li><strong>Execution state</strong> is tracked per-run in <code>automation.runtime.line</code></li>
                        </ul>
                    </div>

                    <div class="alert alert-warning" role="alert" invisible="predecessor_ids">
                        <i class="fa-solid fa-triangle-exclamation" title="Warning" />
                        This is a <strong>root action</strong> — it starts as soon as the workflow runs.
                    </div>

                </page>
            </xpath>

        </field>
    </record>

</odoo>
