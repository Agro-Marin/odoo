<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- Module Category -->
    <record id="module_category_credential_manager" model="ir.module.category">
        <field name="name">Credential Manager</field>
        <field name="description">Manage encrypted credentials and API keys</field>
        <field name="sequence" eval="10" />
    </record>

    <!-- Privilege -->
    <record id="res_groups_privilege_credential_manager" model="res.groups.privilege">
        <field name="name">Credential Manager</field>
        <field name="category_id" ref="module_category_credential_manager" />
        <field name="description">Access to encrypted credential management</field>
        <field name="placeholder">Set credential manager access level...</field>
        <field name="sequence" eval="10" />
    </record>

    <!-- User Group (View credentials) -->
    <record id="group_credential_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="res_groups_privilege_credential_manager" />
        <field name="sequence" eval="10" />
        <field name="implied_ids" eval="[Command.link(ref('base.group_user'))]" />
        <field name="comment">Can view and use credentials (read, write, create)</field>
    </record>

    <!-- Administrator Group (Full access including delete) -->
    <!-- Implies base.group_system because every credential payload field
         (credential_value, username/password, oauth tokens, certificate
         content, ...) is restricted to system admins for security. Without
         this link a "Credential Manager / Administrator" could not enter or
         read any secret — the group would be decorative. Same pattern as
         api_gateway.group_api_gateway_admin. -->
    <record id="group_credential_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="privilege_id" ref="res_groups_privilege_credential_manager" />
        <field name="sequence" eval="20" />
        <field
            name="implied_ids"
            eval="[
            Command.link(ref('group_credential_user')),
            Command.link(ref('base.group_system')),
        ]"
        />
        <field name="comment">Full access including credential deletion and audit log management</field>
    </record>

    <!--
        Unified "Integrations" access ladder for the whole API suite.

        Each module in the suite (credentials, communication, gateway, webhooks,
        OCR) keeps its own per-module groups for granular control, but these
        three canonical groups let an administrator grant suite-wide access in
        ONE place instead of four. Every downstream module links its own groups
        into these via Command.link in its own security file, so:
            Integration User    -> every module's User group
            Integration Manager -> User + the (single) real Manager tier
            Integration Admin    -> Manager + every module's top/admin tier
        Granting an Integration group cascades through implied_ids; the existing
        per-module groups and ACLs are unchanged, so external modules that
        reference them keep working.
    -->
    <record id="module_category_integration" model="ir.module.category">
        <field name="name">Integrations</field>
        <field name="description">Unified access to the API integration suite</field>
        <field name="sequence" eval="5" />
    </record>

    <record id="res_groups_privilege_integration" model="res.groups.privilege">
        <field name="name">Integrations (all API modules)</field>
        <field name="category_id" ref="module_category_integration" />
        <field name="description">Suite-wide access to every API integration module</field>
        <field name="placeholder">Set suite-wide integration access level...</field>
        <field name="sequence" eval="5" />
    </record>

    <record id="group_integration_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="res_groups_privilege_integration" />
        <field name="sequence" eval="10" />
        <field name="implied_ids"
            eval="[Command.link(ref('base.group_user')), Command.link(ref('group_credential_user'))]" />
        <field name="comment">Suite-wide read/use access across all API integration modules.</field>
    </record>

    <record id="group_integration_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="res_groups_privilege_integration" />
        <field name="sequence" eval="20" />
        <field name="implied_ids" eval="[Command.link(ref('group_integration_user'))]" />
        <field name="comment">Suite-wide manager access (monitoring, retries, configuration).</field>
    </record>

    <record id="group_integration_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="privilege_id" ref="res_groups_privilege_integration" />
        <field name="sequence" eval="30" />
        <field name="implied_ids"
            eval="[Command.link(ref('group_integration_manager')), Command.link(ref('group_credential_admin'))]" />
        <field name="comment">Full suite-wide administration across all API integration modules.</field>
    </record>

</odoo>
