<?xml version="1.0" encoding="UTF-8" ?>
<odoo noupdate="1">

    <!-- API Key -->
    <record id="credential_category_api_key" model="credential.category">
        <field name="name">API Key</field>
        <field name="code">api_key</field>
        <field name="storage_hint">simple</field>
        <field name="icon">fa-key</field>
        <field name="sequence" eval="10" />
        <field name="description">Simple API key for authenticating with external services. Store
            the key in the credential value field.</field>
    </record>

    <!-- AWS IAM -->
    <record id="credential_category_aws_iam" model="credential.category">
        <field name="name">AWS IAM</field>
        <field name="code">aws_iam</field>
        <field name="storage_hint">json</field>
        <field name="icon">fa-amazon</field>
        <field name="sequence" eval="50" />
        <field name="description">AWS IAM credentials. Fill "Access Key ID" into the
            api_key field and "Secret Access Key" into api_secret. Both are required and
            stored inside the encrypted JSON blob under those exact keys.</field>
    </record>

    <!-- Basic Authentication -->
    <record id="credential_category_basic_auth" model="credential.category">
        <field name="name">Basic Authentication</field>
        <field name="code">basic_auth</field>
        <field name="storage_hint">json</field>
        <field name="icon">fa-user-secret</field>
        <field name="sequence" eval="40" />
        <field name="description">Username and password for HTTP Basic Authentication. Use JSON
            storage: {"username": "...", "password": "..."}</field>
    </record>

    <!-- Bearer Token -->
    <record id="credential_category_bearer_token" model="credential.category">
        <field name="name">Bearer Token</field>
        <field name="code">bearer_token</field>
        <field name="storage_hint">simple</field>
        <field name="icon">fa-ticket</field>
        <field name="sequence" eval="20" />
        <field name="description">Bearer token for OAuth-style authentication. Store the token in
            the credential value field.</field>
    </record>

    <!-- Certificate -->
    <record id="credential_category_certificate" model="credential.category">
        <field name="name">Certificate</field>
        <field name="code">certificate</field>
        <field name="storage_hint">certificate</field>
        <field name="icon">fa-certificate</field>
        <field name="sequence" eval="60" />
        <!-- Certificates should be automatically validated for expiration -->
        <field name="default_auto_validate_health" eval="True" />
        <!-- Rate limiting less critical for cert operations -->
        <field name="default_rate_limit_max_attempts">50</field>
        <field name="description">X.509 certificate and private key for digital signing and
            encryption. Supports DER, PEM, and PKCS12 formats.</field>
    </record>

    <!-- Custom -->
    <record id="credential_category_custom" model="credential.category">
        <field name="name">Custom</field>
        <field name="code">custom</field>
        <field name="storage_hint">simple</field>
        <field name="icon">fa-cog</field>
        <field name="sequence" eval="100" />
        <field name="description">Custom credential type for specialized use cases. Choose
            appropriate storage (simple or JSON) based on your needs.</field>
    </record>

    <!-- OAuth 2.0 -->
    <record id="credential_category_oauth2" model="credential.category">
        <field name="name">OAuth 2.0</field>
        <field name="code">oauth2</field>
        <field name="storage_hint">json</field>
        <field name="icon">fa-exchange</field>
        <field name="sequence" eval="30" />
        <!-- OAuth tokens are frequently accessed for refresh -->
        <field name="default_rate_limit_max_attempts">200</field>
        <field name="description">OAuth 2.0 credentials. Required: oauth_access_token or
            oauth_client_secret (a pre-authorization credential holds only the client
            secret until the first token exchange). Optional: oauth_client_id,
            oauth_refresh_token, oauth_token_date_expiration. Fields are stored
            inside the encrypted JSON blob under those exact keys; set them via the form.</field>
    </record>

</odoo>
