<?xml version="1.0" encoding="UTF-8" ?>
<odoo noupdate="1">

    <!-- Automated Credential Health Check Cron -->
    <record id="ir_cron_validate_credentials" model="ir.cron">
        <field name="name">Credential Manager: Validate Credentials Health</field>
        <field name="model_id" ref="model_credential_credential" />
        <field name="state">code</field>
        <field name="code">model.cron_validate_credentials()</field>
        <field name="interval_number" eval="1" />
        <field name="interval_type">hours</field>
        <field name="active" eval="True" />
        <field name="priority" eval="50" />
        <field name="user_id" ref="base.user_root" />
    </record>

    <!-- Cleanup Old Rate Limit Buckets (Daily at 3 AM) -->
    <record id="ir_cron_cleanup_old_buckets" model="ir.cron">
        <field name="name">Credential Manager: Cleanup Old Rate Limit Buckets</field>
        <field name="model_id" ref="model_rate_limit_bucket" />
        <field name="state">code</field>
        <field name="code">model.cron_gc_old_buckets()</field>
        <field name="interval_number" eval="1" />
        <field name="interval_type">days</field>
        <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).replace(hour=3, minute=0, second=0)" />
        <field name="active" eval="True" />
        <field name="priority" eval="50" />
        <field name="user_id" ref="base.user_root" />
    </record>

    <!-- Cleanup In-Memory Rate Limiter (Every 4 hours) -->
    <record id="ir_cron_cleanup_rate_limiter" model="ir.cron">
        <field name="name">Credential Manager: Cleanup In-Memory Rate Limiter</field>
        <field name="model_id" ref="model_credential_credential" />
        <field name="state">code</field>
        <field name="code">model.cron_cleanup_rate_limiter()</field>
        <field name="interval_number" eval="4" />
        <field name="interval_type">hours</field>
        <field name="active" eval="True" />
        <field name="priority" eval="60" />
        <field name="user_id" ref="base.user_root" />
    </record>

    <!-- Cleanup Old Access Logs (Weekly, retain 365 days) -->
    <record id="ir_cron_cleanup_access_logs" model="ir.cron">
        <field name="name">Credential Manager: Cleanup Old Access Logs</field>
        <field name="model_id" ref="model_credential_access_log" />
        <field name="state">code</field>
        <field name="code">model.cron_cleanup_old_logs(retention_days=365)</field>
        <field name="interval_number" eval="1" />
        <field name="interval_type">weeks</field>
        <field name="nextcall" eval="(DateTime.now() + timedelta(days=7)).replace(hour=4, minute=0, second=0)" />
        <field name="active" eval="True" />
        <field name="priority" eval="70" />
        <field name="user_id" ref="base.user_root" />
    </record>

</odoo>
