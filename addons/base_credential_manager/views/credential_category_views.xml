<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- Credential Category Search View -->
    <record id="view_credential_category_search" model="ir.ui.view">
        <field name="name">credential.category.search</field>
        <field name="model">credential.category</field>
        <field name="arch" type="xml">
            <search string="Credential Categories">
                <field name="name" />
                <field name="code" />
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]" />
                <group>
                    <filter string="Storage Type" name="group_by_storage" context="{'group_by': 'storage_hint'}" />
                </group>
            </search>
        </field>
    </record>

    <!-- Credential Category List View -->
    <record id="view_credential_category_list" model="ir.ui.view">
        <field name="name">credential.category.list</field>
        <field name="model">credential.category</field>
        <field name="arch" type="xml">
            <list string="Credential Categories">
                <field name="sequence" widget="handle" />
                <field name="icon" />
                <field name="name" />
                <field name="code" />
                <field name="storage_hint" />
                <field name="credential_count" />
                <field name="active" widget="boolean_toggle" />
            </list>
        </field>
    </record>

    <!-- Credential Category Form View -->
    <record id="view_credential_category_form" model="ir.ui.view">
        <field name="name">credential.category.form</field>
        <field name="model">credential.category</field>
        <field name="arch" type="xml">
            <form string="Credential Category">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options='{"terminology": "archive"}' />
                        </button>
                        <button
                            class="oe_stat_button"
                            type="action"
                            icon="fa-key"
                            name="%(action_credential_credential)d"
                            context="{'search_default_category_id': id}"
                        >
                            <field name="credential_count" widget="statinfo" string="Credentials" />
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Category Name" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code" />
                            <field name="storage_hint" />
                        </group>
                        <group>
                            <field name="sequence" />
                            <field name="icon" />
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1" placeholder="Description of this credential type..." />
                    </group>
                    <group string="Default Settings for Credentials">
                        <group>
                            <field name="default_enable_rate_limiting" />
                            <field
                                name="default_rate_limit_max_attempts"
                                invisible="not default_enable_rate_limiting"
                            />
                        </group>
                        <group>
                            <field name="default_auto_validate_health" />
                            <field name="default_allow_key_fallback" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Credential Category Action -->
    <record id="action_credential_category" model="ir.actions.act_window">
        <field name="name">Credential Categories</field>
        <field name="res_model">credential.category</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first credential category
            </p>
            <p>
                Define categories for different types of credentials (API Keys, Certificates, OAuth,
                etc.)
            </p>
        </field>
    </record>

</odoo>
