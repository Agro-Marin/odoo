<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- Shared top-level app for the whole API-integration suite. Every module
         in the suite (credentials, communication, gateway, webhooks, OCR) hangs
         its section under this single root instead of adding its own top-level
         app — one coherent tree rather than five. No groups here: Odoo shows the
         app when the user can reach at least one child, and each child keeps its
         own group filter. -->
    <menuitem
        id="menu_integrations_root"
        name="Integrations"
        sequence="90"
        web_icon="base_credential_manager,static/description/icon.png"
    />

    <!-- Credentials section -->
    <menuitem
        id="menu_credential_root"
        name="Credentials"
        parent="menu_integrations_root"
        sequence="10"
        groups="group_credential_user"
    />

    <!-- Credentials Submenu -->
    <menuitem
        id="menu_credential_credentials"
        name="Credentials"
        parent="menu_credential_root"
        action="action_credential_credential"
        sequence="10"
    />

    <!-- Categories Submenu (Admin only) -->
    <menuitem
        id="menu_credential_categories"
        name="Categories"
        parent="menu_credential_root"
        action="action_credential_category"
        groups="group_credential_admin"
        sequence="20"
    />

    <!-- Access Logs Submenu (Admin only) -->
    <menuitem
        id="menu_credential_access_logs"
        name="Access Logs"
        parent="menu_credential_root"
        action="action_credential_access_log"
        groups="group_credential_admin"
        sequence="30"
    />

    <!-- Configuration Menu -->
    <menuitem
        id="menu_credential_configuration"
        name="Configuration"
        parent="menu_credential_root"
        groups="group_credential_admin"
        sequence="100"
    />

    <!-- Rate Limit Buckets (under Configuration) -->
    <menuitem
        id="menu_credential_rate_limits"
        name="Rate Limit Buckets"
        parent="menu_credential_configuration"
        action="action_rate_limit_bucket"
        groups="group_credential_admin"
        sequence="10"
    />

    <!-- Menu under Technical Settings -->
    <menuitem
        id="menu_rate_limit_bucket"
        name="Rate Limit Buckets"
        parent="base.menu_custom"
        action="action_rate_limit_bucket"
        sequence="100"
        groups="base.group_system"
    />

</odoo>
