<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- Credential Access Log List View -->
    <record id="view_credential_access_log_list" model="ir.ui.view">
        <field name="name">credential.access.log.list</field>
        <field name="model">credential.access.log</field>
        <field name="arch" type="xml">
            <list string="Credential Access Logs" create="0" edit="0" delete="0">
                <field name="timestamp" />
                <field name="credential_id" />
                <field name="user_id" />
                <field name="company_id" groups="base.group_multi_company" />
                <field name="operation" />
                <field name="source_ip" />
            </list>
        </field>
    </record>

    <!-- Credential Access Log Action -->
    <record id="action_credential_access_log" model="ir.actions.act_window">
        <field name="name">Credential Access Logs</field>
        <field name="res_model">credential.access.log</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
