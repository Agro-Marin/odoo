<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- Credential Search View -->
    <record id="view_credential_credential_search" model="ir.ui.view">
        <field name="name">credential.credential.search</field>
        <field name="model">credential.credential</field>
        <field name="arch" type="xml">
            <search string="Credentials">
                <field name="name" />
                <field name="category_id" />
                <field name="company_id" />
                <field name="user_id" />
                <filter string="Healthy" name="healthy" domain="[('health_status', '=', 'healthy')]" />
                <filter string="Error" name="error" domain="[('health_status', '=', 'error')]" />
                <filter string="Certificates" name="certificates" domain="[('category_code', '=', 'certificate')]" />
                <filter
                    string="Valid Certificates"
                    name="valid_certificates"
                    domain="[('category_code', '=', 'certificate'), ('certificate_date_start', '&lt;=', context_today().strftime('%Y-%m-%d')), ('certificate_date_end', '&gt;=', context_today().strftime('%Y-%m-%d'))]"
                />
                <filter string="Expired" name="expired" domain="[('is_expired', '=', True)]" />
                <filter
                    string="Expiring Soon"
                    name="expiring_soon"
                    domain="[('date_expiration', '!=', False), ('date_expiration', '&gt;=', context_today().strftime('%Y-%m-%d')), ('date_expiration', '&lt;=', (context_today() + relativedelta(days=30)).strftime('%Y-%m-%d'))]"
                />
                <separator />
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]" />
                <group>
                    <filter string="Category" name="group_by_category" context="{'group_by': 'category_id'}" />
                    <filter string="Company" name="group_by_company" context="{'group_by': 'company_id'}" />
                    <filter string="Health Status" name="group_by_health" context="{'group_by': 'health_status'}" />
                    <filter string="Created By" name="group_by_user" context="{'group_by': 'user_id'}" />
                </group>
            </search>
        </field>
    </record>

    <!-- Credential List View -->
    <record id="view_credential_credential_list" model="ir.ui.view">
        <field name="name">credential.credential.list</field>
        <field name="model">credential.credential</field>
        <field name="arch" type="xml">
            <list string="Credentials">
                <field name="sequence" widget="handle" />
                <field name="name" />
                <field name="category_id" />
                <field name="category_code" column_invisible="1" />
                <field name="company_id" groups="base.group_multi_company" />
                <field
                    name="health_status"
                    widget="badge"
                    decoration-success="health_status == 'healthy'"
                    decoration-warning="health_status == 'warning'"
                    decoration-danger="health_status == 'error'"
                />
                <field name="certificate_is_valid" string="Cert Valid" invisible="category_code != 'certificate'" />
                <field
                    name="is_expired"
                    string="Expired"
                    widget="boolean"
                    decoration-danger="is_expired"
                    invisible="category_code == 'certificate'"
                />
                <field name="usage_count" optional="hide" />
                <field name="success_rate" optional="hide" />
                <field name="last_used_at" />
                <field name="user_id" optional="hide" />
                <field name="active" widget="boolean_toggle" />
            </list>
        </field>
    </record>

    <!-- Credential Form View -->
    <record id="view_credential_credential_form" model="ir.ui.view">
        <field name="name">credential.credential.form</field>
        <field name="model">credential.credential</field>
        <field name="arch" type="xml">
            <form string="Credential">
                <header>
                    <button
                        name="action_validate_credential"
                        string="Validate Credential"
                        type="object"
                        class="oe_highlight"
                    />
                    <button
                        name="action_test_encryption_keys"
                        string="Test Decryption"
                        type="object"
                        groups="base.group_system"
                        help="Test if this credential can be decrypted with available keys"
                    />
                </header>
                <sheet>
                    <!-- Hidden fields for dynamic visibility -->
                    <field name="category_code" invisible="1" />
                    <field name="storage_hint" invisible="1" />
                    <field name="storage_method" invisible="1" />
                    <field name="category_description" invisible="1" />
                    <field name="certificate_is_valid" invisible="1" />
                    <field name="certificate_date_end" invisible="1" />
                    <field name="certificate_format" invisible="1" />
                    <field name="certificate_loading_error" invisible="1" />
                    <field name="health_message" invisible="1" />
                    <field name="is_expired" invisible="1" />
                    <field name="date_expiration" invisible="1" />

                    <div class="oe_button_box" name="button_box">
                    </div>
                    <!-- Expired ribbon: for certificates or general expiration -->
                    <widget
                        name="web_ribbon"
                        title="Expired"
                        bg_color="text-bg-danger"
                        invisible="not is_expired and (category_code != 'certificate' or certificate_is_valid or not certificate_date_end)"
                    />
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Credential Name" />
                        </h1>
                    </div>

                    <!-- Basic Information -->
                    <group>
                        <group>
                            <field name="category_id" options="{'no_create': True}" />
                            <field name="company_id" groups="base.group_multi_company" />
                            <field name="user_id" readonly="1" />
                        </group>
                        <group>
                            <field name="sequence" />
                            <field
                                name="health_status"
                                widget="badge"
                                decoration-success="health_status == 'healthy'"
                                decoration-warning="health_status == 'warning'"
                                decoration-danger="health_status == 'error'"
                            />
                            <field name="last_used_at" />
                        </group>
                    </group>

                    <!-- Category Description (help text) -->
                    <group invisible="not category_description">
                        <div class="alert alert-info mb-0" role="alert">
                            <i class="fa-solid fa-info-circle me-1" title="Information" />
                            <field name="category_description" nolabel="1" readonly="1" class="oe_inline" />
                        </div>
                    </group>

                    <!-- ==================== API KEY SECTION ==================== -->
                    <group string="API Key" groups="base.group_system" invisible="category_code != 'api_key'">
                        <field
                            name="credential_value"
                            password="True"
                            string="API Key"
                            placeholder="Enter your API key..."
                            required="category_code == 'api_key'"
                        />
                    </group>

                    <!-- ==================== BEARER TOKEN SECTION ==================== -->
                    <group
                        string="Bearer Token"
                        groups="base.group_system"
                        invisible="category_code != 'bearer_token'"
                    >
                        <field
                            name="credential_value"
                            password="True"
                            string="Token"
                            placeholder="Enter your bearer token..."
                            required="category_code == 'bearer_token'"
                        />
                    </group>

                    <!-- ==================== BASIC AUTH SECTION ==================== -->
                    <group
                        string="Basic Authentication"
                        groups="base.group_system"
                        invisible="category_code != 'basic_auth'"
                    >
                        <group>
                            <field
                                name="username"
                                string="Username"
                                placeholder="Enter username..."
                                required="category_code == 'basic_auth'"
                            />
                        </group>
                        <group>
                            <field
                                name="password"
                                password="True"
                                string="Password"
                                placeholder="Enter password..."
                                required="category_code == 'basic_auth'"
                            />
                        </group>
                    </group>

                    <!-- ==================== OAUTH 2.0 SECTION ==================== -->
                    <group string="OAuth 2.0 Tokens" groups="base.group_system" invisible="category_code != 'oauth2'">
                        <group>
                            <field
                                name="oauth_access_token"
                                password="True"
                                string="Access Token"
                                placeholder="Enter access token..."
                                required="category_code == 'oauth2'"
                            />
                            <field name="oauth_token_date_expiration" string="Token Expires At" />
                        </group>
                        <group>
                            <field
                                name="oauth_refresh_token"
                                password="True"
                                string="Refresh Token"
                                placeholder="Enter refresh token (optional)..."
                            />
                        </group>
                    </group>

                    <!-- ==================== AWS IAM SECTION ==================== -->
                    <group
                        string="AWS IAM Credentials"
                        groups="base.group_system"
                        invisible="category_code != 'aws_iam'"
                    >
                        <group>
                            <field
                                name="api_key"
                                password="True"
                                string="Access Key ID"
                                placeholder="AKIA..."
                                required="category_code == 'aws_iam'"
                            />
                        </group>
                        <group>
                            <field
                                name="api_secret"
                                password="True"
                                string="Secret Access Key"
                                placeholder="Enter secret access key..."
                                required="category_code == 'aws_iam'"
                            />
                        </group>
                    </group>

                    <!-- ==================== CUSTOM CREDENTIAL SECTION ==================== -->
                    <group string="Custom Credential" groups="base.group_system" invisible="category_code != 'custom'">
                        <field
                            name="credential_value"
                            password="True"
                            string="Secret Value"
                            placeholder="Enter your secret value..."
                        />
                        <field
                            name="credential_data"
                            string="Additional Data (JSON)"
                            placeholder='{"key": "value", ...}'
                        />
                    </group>

                    <!-- ==================== CERTIFICATE SECTION ==================== -->
                    <group
                        string="Certificate Upload"
                        groups="base.group_system"
                        invisible="category_code != 'certificate'"
                    >
                        <group>
                            <field
                                name="certificate_content"
                                filename="certificate_filename"
                                string="Certificate File"
                                required="category_code == 'certificate'"
                            />
                            <field name="certificate_filename" invisible="1" />
                            <field
                                name="certificate_password"
                                password="True"
                                placeholder="Required for encrypted certificates or PKCS12"
                            />
                        </group>
                        <group>
                            <field
                                name="private_key_content"
                                filename="private_key_filename"
                                string="Private Key File"
                                invisible="certificate_format == 'pkcs12'"
                                help="Not needed for PKCS12 - key is included in certificate"
                            />
                            <field name="private_key_filename" invisible="1" />
                        </group>
                    </group>

                    <!-- Certificate Details (computed from uploaded file) -->
                    <group
                        string="Certificate Details"
                        invisible="category_code != 'certificate' or not certificate_format"
                    >
                        <group>
                            <field name="certificate_format" readonly="1" />
                            <field name="certificate_subject" readonly="1" />
                            <field name="certificate_serial" readonly="1" />
                        </group>
                        <group>
                            <field name="certificate_date_start" readonly="1" />
                            <field name="certificate_date_end" readonly="1" />
                            <field name="certificate_is_valid" readonly="1" widget="boolean" />
                        </group>
                    </group>

                    <!-- Certificate Error Alert -->
                    <group invisible="category_code != 'certificate' or not certificate_loading_error">
                        <div class="alert alert-danger" role="alert">
                            <strong>Certificate Error:</strong>
                            <field name="certificate_loading_error" nolabel="1" readonly="1" />
                        </div>
                    </group>

                    <!-- Certificate Expiration Warning -->
                    <group
                        invisible="category_code != 'certificate' or certificate_is_valid or not certificate_date_end"
                    >
                        <div class="alert alert-warning" role="alert">
                            <strong>Certificate Expired!</strong> This certificate expired on <field
                                name="certificate_date_end"
                                readonly="1"
                                nolabel="1"
                                class="oe_inline"
                            />. Please upload a new certificate. </div>
                    </group>

                    <!-- ==================== ADVANCED OPTIONS ==================== -->
                    <group string="Advanced Options" name="group_advanced_options" groups="base.group_system">
                        <group>
                            <field name="auto_validate_health" />
                            <field name="last_health_check" readonly="1" />
                        </group>
                        <group>
                            <field name="enable_rate_limiting" />
                            <field name="rate_limit_max_attempts" invisible="not enable_rate_limiting" />
                        </group>
                    </group>

                    <!-- Encryption Key Management -->
                    <group
                        string="Encryption Key Status"
                        groups="base.group_system"
                        invisible="not encryption_key_version"
                    >
                        <group>
                            <field name="encryption_key_version" readonly="1" />
                            <field name="allow_key_fallback" />
                        </group>
                    </group>

                    <!-- Key Rotation Warnings -->
                    <group
                        groups="base.group_system"
                        invisible="not encryption_key_version or encryption_key_version == 0"
                    >
                        <div class="alert alert-warning" role="alert">
                            <strong>Old Encryption Key!</strong> This credential was encrypted with
                            key version <field
                                name="encryption_key_version"
                                readonly="1"
                                nolabel="1"
                                class="oe_inline"
                            /> (not current). Use "Migrate
                            Encryption Keys" action to update. </div>
                    </group>

                    <group groups="base.group_system" invisible="allow_key_fallback">
                        <div class="alert alert-info" role="alert">
                            <strong>Key Fallback Disabled</strong> This credential will fail if
                            current key doesn't work. Enable fallback for compatibility during key
                            rotation. </div>
                    </group>

                    <!-- ==================== EXPIRATION TRACKING ==================== -->
                    <group
                        string="Expiration"
                        name="group_expiration"
                        groups="base.group_system"
                        invisible="category_code == 'certificate'"
                    >
                        <group>
                            <field name="date_expiration" />
                        </group>
                        <group>
                            <field name="days_until_expiry" readonly="1" invisible="not date_expiration" />
                            <field name="is_expired" readonly="1" widget="boolean" invisible="not date_expiration" />
                        </group>
                    </group>

                    <!-- Expiration Warning for non-certificate credentials -->
                    <group invisible="category_code == 'certificate' or not is_expired">
                        <div class="alert alert-warning" role="alert">
                            <strong>Credential Expired!</strong> This credential expired on <field
                                name="date_expiration"
                                readonly="1"
                                nolabel="1"
                                class="oe_inline"
                            />.
                            Please renew or update this credential. </div>
                    </group>

                    <!-- ==================== USAGE STATISTICS ==================== -->
                    <group string="Usage Statistics" name="group_usage_statistics" groups="base.group_system">
                        <group>
                            <field name="usage_count" readonly="1" />
                            <field name="success_count" readonly="1" />
                        </group>
                        <group>
                            <field name="error_count" readonly="1" />
                            <field name="success_rate" readonly="1" string="Success Rate (%)" />
                        </group>
                    </group>

                    <!-- ==================== NOTES ==================== -->
                    <group string="Notes" name="group_notes" groups="base.group_system">
                        <field name="notes" nolabel="1" placeholder="Additional notes or documentation..." />
                    </group>

                    <!-- Health Status Message -->
                    <group string="Health Check Result" invisible="not health_message">
                        <field name="health_message" nolabel="1" readonly="1" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Credential Action -->
    <record id="action_credential_credential" model="ir.actions.act_window">
        <field name="name">Credentials</field>
        <field name="res_model">credential.credential</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_group_by_category': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first credential
            </p>
            <p>
                Manage credentials for external service integrations securely.
                Supports API keys, OAuth tokens, certificates, and more.
            </p>
        </field>
    </record>

    <!-- Encryption Key Migration Action -->
    <record id="action_migrate_encryption_keys" model="ir.actions.server">
        <field name="name">Migrate Encryption Keys</field>
        <field name="model_id" ref="model_credential_credential" />
        <field name="binding_model_id" ref="model_credential_credential" />
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
result = model.action_migrate_encryption_keys()
if result:
    title = "Encryption Key Migration Complete"
    message = f"""Migration Results:
- Total credentials: {result['total']}
- Successfully migrated: {result['migrated']}
- Failed: {result['failed']}
- Target key version: {result['current_key_version']}"""
    if result['errors']:
        message += f"\n\nErrors:\n" + "\n".join(result['errors'][:5])
        if len(result['errors']) &gt; 5:
            message += f"\n... and {len(result['errors']) - 5} more errors"

    action = {
        'type': 'ir.actions.client',
        'tag': 'display_notification',
        'params': {
            'title': title,
            'message': message,
            'type': 'success' if result['failed'] == 0 else 'warning',
            'sticky': True,
        }
    }
        </field>
        <field name="group_ids" eval="[Command.link(ref('base.group_system'))]" />
    </record>

</odoo>
