<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Rows template of MovesListRenderer (stock_move_one2many.js): adds the
         "Move a Pack" row action to the picking's moves list. -->
    <t t-name="stock.MovesListRendererRows" t-inherit="web.ListRenderer.Rows" t-inherit-mode="primary">
        <td class="o_field_x2many_list_row_add" position="inside">
            <a t-if="canAddPackage" href="#" class="px-3" tabindex="0" t-on-click.stop.prevent="() => this.onClickMovePackage()">Move a Pack</a>
        </td>
    </t>
</templates>
