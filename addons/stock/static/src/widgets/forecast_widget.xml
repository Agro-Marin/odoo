<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="stock.ForecastWidget">
        <!-- A real button: the badge opens the Forecasted Report on click, so it
             must be focusable and keyboard-activatable. -->
        <button type="button" title="Forecasted Report" aria-label="Forecasted Report"
              t-on-click="_openReport"
              class="badge rounded-pill align-middle border-0"
              t-att-class="decoration"
        >
            <t t-if="status === 'available'">
                Available
            </t>
            <t t-elif="status === 'expected'">
                Exp <t t-out="forecastExpectedDate"/>
            </t>
            <t t-else="">Not Available</t>
        </button>
    </t>

</templates>
