<?xml version="1.0" encoding="utf-8"?>
<templates>

    <div t-name="stock.PopoverStockRescheduling">
        <h6>Planning Issue</h6>
        <p>
            <t t-out="precedingLabel"/>
            <t t-foreach="props.late_elements" t-as="late_element" t-key="late_element.id">
                <a t-out="late_element.name" t-on-click.prevent="openElement" href="#" t-att-element-id="late_element.id" t-att-element-model="late_element.model"/><t t-if="!late_element_last">, </t>
            </t>
            <br/>
            <t t-out="plannedLabel"/>
        </p>
    </div>
</templates>
