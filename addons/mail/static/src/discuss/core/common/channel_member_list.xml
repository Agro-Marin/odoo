<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="discuss.ChannelMemberList">
        <ActionPanel close="this.props.close" title.translate="Members" minWidth="200" initialWidth="this.env.inMeetingView ? 400 : 250" icon="'oi oi-users'">
            <div class="o-discuss-ChannelMemberList-search d-flex flex-nowrap gap-1">
                <SearchInput search="this.search" placeholder.translate="Search members"/>
                <button name="inviteButton" t-on-click="() => this.openChannelInvitationDialog(this.env, this.props.channel)" class="btn btn-sm btn-primary text-nowrap" title="Add People" aria-label="Add People">Add People</button>
            </div>
            <t t-foreach="this.groupedCategories(this.categories())" t-as="group" t-key="group_index">
                <t t-set="groupHasMembers" t-value="group.categories.some((c) => c.filtered.length > 0)"/>
                <div t-if="group.sequenceGroup and groupHasMembers" class="o-discuss-ChannelMemberList-group border rounded-3 mt-2 p-2">
                    <t t-foreach="group.categories" t-as="category" t-key="category_index">
                        <t t-call="discuss.ChannelMemberList.category"/>
                    </t>
                </div>
                <t t-elif="!group.sequenceGroup">
                    <t t-foreach="group.categories" t-as="category" t-key="category_index">
                        <t t-call="discuss.ChannelMemberList.category"/>
                    </t>
                </t>
            </t>
            <span t-if="this.search.searchTerm and !this.search.loading and !this.hasFilteredMembers(this.categories())" class="mx-2 mt-2 text-muted">No members found.</span>
            <span t-if="this.isSearchResultCapped" class="smaller text-muted mx-1 mb-1 fst-italic" t-out="this.searchResultCapHint"/>
            <t t-if="!this.search.searchTerm">
                <span t-if="this.props.channel.unknownMembersCount === 1" class="mx-2 mt-2">And 1 other member.</span>
                <span t-if="this.props.channel.unknownMembersCount > 1" class="mx-2 mt-2">And <t t-out="this.props.channel.unknownMembersCount"/> other members.</span>
                <div t-if="!this.props.channel.areAllMembersLoaded" class="mx-2 my-1">
                    <button class="btn btn-secondary" title="Load more" t-on-click.stop="() => this.props.channel.fetchChannelMembers()">Load more</button>
                </div>
            </t>
        </ActionPanel>
    </t>

    <t t-name="discuss.ChannelMemberList.category">
        <t t-if="category.filtered.length > 0">
            <t t-call="discuss.ChannelMemberList.section"/>
            <div class="d-flex flex-column bg-inherit gap-1">
                <ChannelMember t-foreach="category.filtered" t-as="member" t-key="member.id" member="member"/>
            </div>
        </t>
    </t>

    <t t-name="discuss.ChannelMemberList.section">
        <h6 class="text-uppercase o-xsmaller opacity-75 d-flex align-items-center gap-1" t-att-class="category.headerClass or 'text-muted pt-3'">
            <i t-if="category.icon" class="me-1 opacity-75" t-att-class="category.icon" role="img"/>
            <span t-out="category.showCount ? `${category.label} - ${category.filtered.length}` : category.label"/>
        </h6>
    </t>

</templates>
