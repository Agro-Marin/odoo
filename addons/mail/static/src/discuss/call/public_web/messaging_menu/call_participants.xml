<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="mail.MessagingMenuCallParticipants">
        <div class="o-mail-MessagingMenuCallParticipants rounded-bottom d-flex bg-inherit px-3 p-1">
            <button class="o-mail-MessagingMenuCallParticipants-expandBtn btn btn-link p-1 my-n1 ms-n1 me-0 align-self-start d-flex rounded-circle" t-on-click.stop="this.toggleFn(this.expanded)">
                <i class="oi o-xxsmaller text-muted text-dark" t-att-class="{'oi-chevron-right': !this.expanded(), 'oi-chevron-down': this.expanded()}" t-att-title="this.title"/>
            </button>
            <AvatarStack
                t-if="!this.expanded()"
                personas="this.personas()"
                size="30"
                max="10"
                avatarClass="(p) => this.avatarClass(p)"
                containerClass="'cursor-pointer'"
                onClick.bind="this.onClickAvatarStack"
            />
            <div t-else="" class="d-flex flex-column gap-1 flex-grow-1 overflow-hidden" style="padding-left: 0.5px;">
                <t t-foreach="this.sessions" t-as="session" t-key="session.localId">
                    <div class="o-mail-MessagingMenuCallParticipants-participant d-flex text-reset overflow-hidden align-items-center" t-att-class="this.participantClass(session)" t-on-click.stop="(ev) => this.onClickParticipant(ev, session)">
                        <div class="bg-inherit position-relative d-flex flex-shrink-0" style="width:30px;height:30px;margin: 1.5px;">
                            <img class="o-mail-MessagingMenuCallParticipants-avatar w-100 h-100 rounded-circle object-fit-cover" t-att-src="session.channel_member_id?.avatarUrl" t-att-class="{'o-isTalking': session.isActuallyTalking}" alt="Participant avatar" t-att-title="session.channel_member_id?.name"/>
                        </div>
                        <span class="o-mail-MessagingMenuCallParticipants-name mx-1 text-truncate fw-bold smaller user-select-none" t-att-title="session.channel_member_id?.name" t-att-class="{ 'o-isTalking': session.isActuallyTalking }">
                            <t t-out="session.channel_member_id?.name"/>
                        </span>
                        <div class="flex-grow-1"/>
                        <div class="o-mail-MessagingMenuCallParticipants-status small opacity-75 ms-1 d-flex align-items-center justify-content-center">
                            <span t-if="session.is_deaf" class="p-1 fa opacity-75" t-att-class="this.CALL_ICON_DEAFEN"/>
                            <span t-elif="session.is_muted" class="p-1 fa opacity-75" t-att-class="this.CALL_ICON_MUTED"/>
                            <span t-if="session.is_screen_sharing_on" class="o-live bg-danger o-text-white rounded">LIVE</span>
                        </div>
                    </div>
                </t>
            </div>
        </div>
    </t>
</templates>
