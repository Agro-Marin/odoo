<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="mail.MessageInDialog">
    <Dialog size="'md'" title="this.title">
        <blockquote class="mx-3 fst-normal">
            <Message message="this.message()" thread="this.message().thread"/>
        </blockquote>
    </Dialog>
</t>

</templates>
