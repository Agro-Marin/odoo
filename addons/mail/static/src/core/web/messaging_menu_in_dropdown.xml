<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

<t t-name="mail.MessagingMenuInDropdown">
    <t t-if="this.env.inDiscussApp" t-call="mail.MessagingMenuInDropdown.content"/>
    <Dropdown t-else="" state="this.dropdown" position="'bottom-end'" menuClass="this.discussSystray.menuClass" bottomSheet="false">
        <button t-att-class="this.discussSystray.class" data-available-offline="">
            <i class="fa fa-lg fa-comments" role="img" aria-label="Messages"/>
            <span t-if="this.store.messagingMenu.globalCounter" class="o-mail-MessagingMenuInDropdown-counter badge rounded-pill"><t t-out="this.store.messagingMenu.globalCounter"/></span>
        </button>
        <t t-set-slot="content">
            <t t-call="mail.MessagingMenuInDropdown.content"/>
        </t>
    </Dropdown>
</t>

<t t-name="mail.MessagingMenuInDropdown.content">
    <div t-att-class="`${this.discussSystray.contentClass} o-mail-MessagingMenuInDropdown`">
        <t name="before-content"/>
        <MessagingMenu close="this.closeDropdown" state="this.menuState"/>
    </div>
</t>

</templates>
