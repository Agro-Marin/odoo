<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="mentorship_list_action" model="ir.actions.act_window">
        <field name="name">Mentorships</field>
        <field name="res_model">gamification.mentorship</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first mentorship
            </p>
            <p>
                Pair experienced users with newcomers. Mentors earn karma
                when their mentee reaches milestones.
            </p>
        </field>
    </record>

    <record id="mentorship_list_view" model="ir.ui.view">
        <field name="name">gamification.mentorship.list</field>
        <field name="model">gamification.mentorship</field>
        <field name="arch" type="xml">
            <list string="Mentorships">
                <field name="mentor_id" widget="many2one_avatar_user"/>
                <field name="mentee_id" widget="many2one_avatar_user"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-info="state == 'completed'"
                       decoration-muted="state == 'cancelled'"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="mentee_milestones_reached"/>
                <field name="total_mentor_karma"/>
            </list>
        </field>
    </record>

    <record id="mentorship_form_view" model="ir.ui.view">
        <field name="name">gamification.mentorship.form</field>
        <field name="model">gamification.mentorship</field>
        <field name="arch" type="xml">
            <form string="Mentorship">
                <header>
                    <button name="action_complete" string="Complete" type="object"
                            class="btn-primary" invisible="state != 'active'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state != 'active'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="active,completed"/>
                </header>
                <sheet>
                    <group>
                        <group string="Pairing">
                            <field name="mentor_id" widget="many2one_avatar_user"
                                   readonly="state != 'active'"/>
                            <field name="mentee_id" widget="many2one_avatar_user"
                                   readonly="state != 'active'"/>
                        </group>
                        <group string="Progress">
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="mentee_milestones_reached"/>
                            <field name="total_mentor_karma"/>
                        </group>
                    </group>
                    <group string="Rewards">
                        <group>
                            <field name="mentor_karma_per_milestone"/>
                            <field name="mentor_karma_on_completion"/>
                        </group>
                        <group>
                            <field name="completion_badge_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Mentorship goals and objectives..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="mentorship_search_view" model="ir.ui.view">
        <field name="name">gamification.mentorship.search</field>
        <field name="model">gamification.mentorship</field>
        <field name="arch" type="xml">
            <search>
                <field name="mentor_id"/>
                <field name="mentee_id"/>
                <filter string="Active" name="active" domain="[('state', '=', 'active')]"/>
                <filter string="Completed" name="completed" domain="[('state', '=', 'completed')]"/>
                <group>
                    <filter string="Mentor" name="group_mentor" context="{'group_by': 'mentor_id'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
