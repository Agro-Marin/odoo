<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="skill_tree_list_action" model="ir.actions.act_window">
        <field name="name">Skill Trees</field>
        <field name="res_model">gamification.skill.tree</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="skill_tree_search_view" model="ir.ui.view">
        <field name="name">gamification.skill.tree.search</field>
        <field name="model">gamification.skill.tree</field>
        <field name="arch" type="xml">
            <search string="Skill Trees">
                <field name="name"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="skill_tree_list_view" model="ir.ui.view">
        <field name="name">gamification.skill.tree.list</field>
        <field name="model">gamification.skill.tree</field>
        <field name="arch" type="xml">
            <list string="Skill Trees">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="node_count"/>
            </list>
        </field>
    </record>

    <record id="skill_tree_form_view" model="ir.ui.view">
        <field name="name">gamification.skill.tree.form</field>
        <field name="model">gamification.skill.tree</field>
        <field name="arch" type="xml">
            <form string="Skill Tree">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-puzzle-piece">
                            <field name="node_count" widget="statinfo" string="Nodes"/>
                        </button>
                    </div>
                    <field name="icon" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Sales Mastery"/></h1>
                    </div>
                    <group>
                        <field name="active"/>
                        <field name="description" placeholder="What this skill tree covers..."/>
                    </group>
                    <field name="node_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="level"/>
                            <field name="name"/>
                            <field name="prerequisite_ids" widget="many2many_tags"/>
                            <field name="karma_threshold"/>
                            <field name="quest_id"/>
                            <field name="karma_reward"/>
                            <field name="badge_id"/>
                            <field name="unlock_count"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Skill Node standalone views for detailed editing -->

    <record id="skill_node_search_view" model="ir.ui.view">
        <field name="name">gamification.skill.node.search</field>
        <field name="model">gamification.skill.node</field>
        <field name="arch" type="xml">
            <search string="Skill Nodes">
                <field name="name"/>
                <field name="tree_id"/>
                <separator/>
                <group>
                    <filter string="Tree" name="group_tree" context="{'group_by': 'tree_id'}"/>
                    <filter string="Level" name="group_level" context="{'group_by': 'level'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="skill_node_list_action" model="ir.actions.act_window">
        <field name="name">Skill Nodes</field>
        <field name="res_model">gamification.skill.node</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="skill_node_form_view" model="ir.ui.view">
        <field name="name">gamification.skill.node.form</field>
        <field name="model">gamification.skill.node</field>
        <field name="arch" type="xml">
            <form string="Skill Node">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Position">
                            <field name="tree_id"/>
                            <field name="level"/>
                            <field name="sequence"/>
                        </group>
                        <group string="Unlock Conditions">
                            <field name="prerequisite_ids" widget="many2many_tags"/>
                            <field name="karma_threshold"/>
                            <field name="quest_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Rewards">
                            <field name="karma_reward"/>
                            <field name="badge_id"/>
                        </group>
                        <group string="Stats">
                            <field name="unlock_count"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="What this skill represents..."/>
                    </group>
                    <group string="Dependents (nodes this unlocks)">
                        <field name="dependent_ids" widget="many2many_tags" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
