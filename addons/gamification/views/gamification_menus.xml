<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Dashboard client action -->
    <record id="gamification_dashboard_action" model="ir.actions.client">
        <field name="name">Gamification Dashboard</field>
        <field name="tag">gamification_dashboard</field>
        <field name="path">gamification-dashboard</field>
    </record>

    <!-- Root menu in settings - technical feature required -->
    <menuitem id="gamification_menu"
              name="Gamification Tools"
              parent="base.menu_administration"
              groups="base.group_no_one" />

    <!-- Dashboard (top level) -->
    <menuitem id="gamification_dashboard_menu"
              parent="gamification_menu"
              action="gamification_dashboard_action"
              sequence="-10"/>

    <!-- ===== Activity ===== -->
    <menuitem id="gamification_activity_parent_menu"
              name="Activity"
              parent="gamification_menu"
              sequence="10"/>
    <menuitem id="gamification_challenge_menu"
              parent="gamification_activity_parent_menu"
              action="challenge_list_action"
              sequence="10"/>
    <menuitem id="gamification_goal_menu"
              parent="gamification_activity_parent_menu"
              action="goal_list_action"
              sequence="20"/>
    <menuitem id="gamification_streak_menu"
              parent="gamification_activity_parent_menu"
              action="streak_list_action"
              sequence="30"/>
    <menuitem id="gamification_kudos_menu"
              parent="gamification_activity_parent_menu"
              action="kudos_list_action"
              sequence="40"/>
    <menuitem id="gamification_quest_menu"
              parent="gamification_activity_parent_menu"
              action="quest_list_action"
              sequence="50"/>

    <!-- ===== Recognition ===== -->
    <menuitem id="gamification_recognition_parent_menu"
              name="Recognition"
              parent="gamification_menu"
              sequence="20"/>
    <menuitem id="gamification_badge_menu"
              parent="gamification_recognition_parent_menu"
              action="badge_list_action"
              sequence="10"/>
    <menuitem id="gamification_achievement_menu"
              parent="gamification_recognition_parent_menu"
              action="achievement_list_action"
              sequence="20"/>
    <menuitem id="gamification_achievement_unlock_menu"
              parent="gamification_recognition_parent_menu"
              action="achievement_unlock_list_action"
              sequence="30"/>
    <menuitem id="gamification_season_menu"
              parent="gamification_recognition_parent_menu"
              action="season_list_action"
              sequence="40"/>

    <!-- ===== Teams &amp; Mentorship ===== -->
    <menuitem id="gamification_teams_parent_menu"
              name="Teams &amp; Mentorship"
              parent="gamification_menu"
              sequence="30"/>
    <menuitem id="gamification_team_menu"
              parent="gamification_teams_parent_menu"
              action="team_list_action"
              sequence="10"/>
    <menuitem id="gamification_mentorship_menu"
              parent="gamification_teams_parent_menu"
              action="mentorship_list_action"
              sequence="20"/>

    <!-- ===== Analytics ===== -->
    <menuitem id="gamification_analytics_parent_menu"
              name="Analytics"
              parent="gamification_menu"
              sequence="40"/>
    <menuitem id="gamification_activity_feed_menu"
              parent="gamification_analytics_parent_menu"
              action="activity_feed_list_action"
              sequence="10"/>
    <menuitem id="gamification_engagement_menu"
              parent="gamification_analytics_parent_menu"
              action="engagement_snapshot_list_action"
              sequence="20"/>

    <!-- ===== Configuration ===== -->
    <menuitem id="gamification_config_parent_menu"
              name="Configuration"
              parent="gamification_menu"
              sequence="50"/>
    <menuitem id="gamification_definition_menu"
              parent="gamification_config_parent_menu"
              action="goal_definition_list_action"
              sequence="10"/>
    <menuitem id="gamification_karma_ranks_menu"
              parent="gamification_config_parent_menu"
              action="gamification_karma_ranks_action"
              sequence="20"/>
    <menuitem id="gamification_karma_tracking_menu"
              parent="gamification_config_parent_menu"
              action="gamification_karma_tracking_action"
              sequence="30"/>
    <menuitem id="gamification_streak_type_menu"
              parent="gamification_config_parent_menu"
              action="streak_type_list_action"
              sequence="40"/>
    <menuitem id="gamification_kudos_category_menu"
              parent="gamification_config_parent_menu"
              action="kudos_category_list_action"
              sequence="50"/>
    <menuitem id="gamification_skill_tree_menu"
              parent="gamification_config_parent_menu"
              action="skill_tree_list_action"
              sequence="60"/>
</odoo>
