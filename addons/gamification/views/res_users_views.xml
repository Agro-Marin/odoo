<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

    <record id="res_users_view_form" model="ir.ui.view">
        <field name="name">res.users.view.form.inherit.gamification</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button type="object" class="oe_stat_button" groups="base.group_no_one"
                    name="action_karma_report" icon="fa-certificate">
                    <field string="Karma" name="karma" widget="statinfo"/>
                </button>
            </xpath>
        </field>
    </record>

    <!-- Gamification tab in user preferences -->
    <record id="res_users_view_form_gamification_prefs" model="ir.ui.view">
        <field name="name">res.users.view.form.gamification.prefs</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Gamification" name="gamification" groups="base.group_no_one">
                    <group>
                        <group string="Level Progress">
                            <field name="rank_id" readonly="1"/>
                            <field name="next_rank_id" readonly="1"/>
                            <field name="xp_progress_percent" widget="progressbar"/>
                            <field name="xp_to_next_rank"/>
                        </group>
                        <group string="Badges">
                            <field name="gold_badge"/>
                            <field name="silver_badge"/>
                            <field name="bronze_badge"/>
                        </group>
                    </group>
                    <group>
                        <group string="Profile Settings">
                            <field name="gamification_visibility"/>
                            <field name="featured_badge_ids" widget="many2many_tags"
                                   domain="[('user_id', '=', id)]"/>
                        </group>
                    </group>
                    <field name="streak_ids" readonly="1" string="Active Streaks">
                        <list>
                            <field name="streak_type_id"/>
                            <field name="current_count"/>
                            <field name="longest_count"/>
                            <field name="last_activity_date"/>
                            <field name="state" widget="badge"
                                   decoration-success="state == 'active'"
                                   decoration-danger="state == 'broken'"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- ACTIONS -->
    <record id="action_current_rank_users" model="ir.actions.act_window">
        <field name="name">Users</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('rank_id', '=', active_id)]</field>
    </record>

    <record id="action_new_simplified_res_users" model="ir.actions.act_window">
        <field name="name">Create User</field>
        <field name="res_model">res.users</field>
        <field name="target">current</field>
        <field name="view_id" ref="base.view_users_simple_form"/>
        <field name="context">{}</field>
        <field name="help">Create and manage users that will connect to the system. Users can be deactivated should there be a period of time during which they will/should not connect to the system. You can assign them groups in order to give them specific access to the applications they need to use in the system.</field>
    </record>

</data>
</odoo>
