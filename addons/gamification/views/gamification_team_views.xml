<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===== Actions ===== -->

    <record id="team_list_action" model="ir.actions.act_window">
        <field name="name">Teams</field>
        <field name="res_model">gamification.team</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first team
            </p>
            <p>
                Teams compete together in team challenges. Create teams
                manually or link them to HR departments.
            </p>
        </field>
    </record>

    <!-- ===== Team Views ===== -->

    <record id="team_list_view" model="ir.ui.view">
        <field name="name">gamification.team.list</field>
        <field name="model">gamification.team</field>
        <field name="arch" type="xml">
            <list string="Teams">
                <field name="name"/>
                <field name="captain_id" widget="many2one_avatar_user"/>
                <field name="member_count"/>
                <field name="team_karma"/>
                <field name="team_badges"/>
            </list>
        </field>
    </record>

    <record id="team_kanban_view" model="ir.ui.view">
        <field name="name">gamification.team.kanban</field>
        <field name="model">gamification.team</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="captain_id"/>
                <field name="member_count"/>
                <field name="team_karma"/>
                <templates>
                    <t t-name="card">
                        <field name="image_128" widget="image" options="{'preview_image': 'image_128'}"/>
                        <div>
                            <strong><field name="name"/></strong>
                        </div>
                        <div>
                            <field name="member_count"/> members
                            | <field name="team_karma"/> karma
                        </div>
                        <footer>
                            <field name="captain_id" widget="many2one_avatar_user"/>
                        </footer>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="team_form_view" model="ir.ui.view">
        <field name="name">gamification.team.form</field>
        <field name="model">gamification.team</field>
        <field name="arch" type="xml">
            <form string="Team">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <field name="image_128" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Alpha Squad"/></h1>
                    </div>
                    <group>
                        <group string="Team Info">
                            <field name="captain_id" widget="many2one_avatar_user"/>
                            <field name="active"/>
                        </group>
                        <group string="Stats">
                            <field name="member_count"/>
                            <field name="team_karma"/>
                            <field name="team_badges"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Members" name="members">
                            <field name="member_ids" widget="many2many_tags"
                                   options="{'color_field': 'color'}"/>
                        </page>
                        <page string="Challenges" name="challenges">
                            <field name="challenge_ids" readonly="1"/>
                        </page>
                        <page string="Description" name="description">
                            <field name="description"
                                   placeholder="Team description, mission, or motto..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="team_search_view" model="ir.ui.view">
        <field name="name">gamification.team.search</field>
        <field name="model">gamification.team</field>
        <field name="arch" type="xml">
            <search string="Teams">
                <field name="name"/>
                <field name="captain_id"/>
                <field name="member_ids"/>
            </search>
        </field>
    </record>

    <!-- ===== Extend Challenge Form for Team Mode ===== -->

    <record id="challenge_form_team_extension" model="ir.ui.view">
        <field name="name">gamification.challenge.form.team</field>
        <field name="model">gamification.challenge</field>
        <field name="inherit_id" ref="challenge_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='visibility_mode']" position="before">
                <field name="challenge_mode" widget="radio"/>
            </xpath>
            <xpath expr="//field[@name='visibility_mode']" position="after">
                <field name="team_ids" widget="many2many_tags"
                       invisible="challenge_mode != 'team'"/>
            </xpath>
        </field>
    </record>

</odoo>
