<odoo noupdate="1">

        <record id="goal_user_visibility" model="ir.rule">
            <field name="name">User can only see his/her goals or goal from the same challenge in board visibility</field>
            <field name="model_id" ref="model_gamification_goal"/>
            <field name="groups" eval="[(4, ref('base.group_user')), (4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="domain_force">[
                '|',
                    ('user_id','=',user.id),
                    '&amp;',
                        ('challenge_id.user_ids','in',user.id),
                        ('challenge_id.visibility_mode','=','ranking')]</field>
        </record>

        <record id="goal_gamification_manager_visibility" model="ir.rule">
            <field name="name">Manager can see any goal</field>
            <field name="model_id" ref="model_gamification_goal"/>
            <field name="groups" eval="[(4, ref('base.group_erp_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="goal_global_multicompany" model="ir.rule">
            <field name="name">Multicompany rule on challenges</field>
            <field name="model_id" ref="model_gamification_goal"/>
            <field name="domain_force">[('user_id.company_id', 'in', company_ids)]</field>
        </record>

        <!-- Streaks: users can only write their own streaks, read all -->
        <record id="streak_user_write" model="ir.rule">
            <field name="name">Users can only modify their own streaks</field>
            <field name="model_id" ref="model_gamification_streak"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
        </record>

        <!-- Kudos: users can only write their own sent kudos, read all -->
        <record id="kudos_user_write" model="ir.rule">
            <field name="name">Users can only modify their own kudos</field>
            <field name="model_id" ref="model_gamification_kudos"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="domain_force">[('sender_id', '=', user.id)]</field>
        </record>

        <!-- Mentorship: an employee may only see and modify pairings they are
             part of.  Without this rule any employee could rewrite a mentorship
             between two other users, name themselves mentor and collect the
             completion payout. -->
        <record id="mentorship_own_only" model="ir.rule">
            <field name="name">Users only see mentorships they take part in</field>
            <field name="model_id" ref="model_gamification_mentorship"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
            <field name="domain_force">[
                '|',
                    ('mentor_id','=',user.id),
                    ('mentee_id','=',user.id)]</field>
        </record>

        <!-- id must not be "mentorship_manager": that xmlid is already taken by
             the ir.model.access row of the same name in ir.model.access.csv. -->
        <record id="mentorship_manager_rule" model="ir.rule">
            <field name="name">Managers see every mentorship</field>
            <field name="model_id" ref="model_gamification_mentorship"/>
            <field name="groups" eval="[(4, ref('base.group_erp_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <!-- Activity feed: enforce the profile-visibility promise at the ORM
             layer.  Filtering only inside get_activity_feed() left the rows
             readable through a plain search_read/read_group. -->
        <record id="activity_visibility" model="ir.rule">
            <field name="name">Activity feed respects profile visibility and company</field>
            <field name="model_id" ref="model_gamification_activity"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="domain_force">[
                '&amp;',
                    ('company_id', 'in', company_ids),
                    '|',
                        ('user_id', '=', user.id),
                        ('user_id.gamification_visibility', '!=', 'private')]</field>
        </record>

        <!-- Engagement snapshots are company-wide analytics; scope them to the
             companies the reader actually belongs to. -->
        <record id="engagement_snapshot_multicompany" model="ir.rule">
            <field name="name">Engagement snapshots are company-scoped</field>
            <field name="model_id" ref="model_gamification_engagement_snapshot"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

</odoo>
