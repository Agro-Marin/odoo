    <record id="view_account_move_line_list_grouped_misc" model="ir.ui.view">
        <field name="name">account.move.line.list.grouped.misc</field>
        <field name="model">account.move.line</field>
        <field name="mode">primary</field>
        <field name="inherit_id" ref="account.view_account_move_line_list" />
        <field name="arch" type="xml">
            <field name="date" position="attributes">
                <attribute name="optional">hide</attribute>
            </field>
        </field>
    </record>

    <record id="view_account_move_line_list_grouped_general" model="ir.ui.view">
        <field name="name">account.move.line.list.grouped.misc</field>
        <field name="model">account.move.line</field>
        <field name="mode">primary</field>
        <field name="inherit_id" ref="account.view_account_move_line_list" />
