    <record id="view_account_move_line_list_grouped_partner" model="ir.ui.view">
        <field name="name">account.move.line.list.grouped.partner</field>
        <field name="model">account.move.line</field>
        <field name="mode">primary</field>
        <field name="inherit_id" ref="account.view_account_move_line_list" />
        <field name="arch" type="xml">
            <field name="partner_id" position="attributes">
                <attribute name="optional">hide</attribute>
            </field>
            <field name="date_maturity" position="attributes">
