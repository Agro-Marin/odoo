<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="srm_tag_view_form" model="ir.ui.view">
        <field name="name">srm.tag.view.form</field>
        <field name="model">srm.tag</field>
        <field name="arch" type="xml">
            <form string="Tag">
                <sheet>
                    <group col="4">
                        <field name="name" placeholder="e.g. Strategic" />
                        <field name="color" widget="color_picker" />
                        <field name="parent_id" />
                        <field name="active" widget="boolean_toggle" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="srm_tag_view_search" model="ir.ui.view">
        <field name="name">srm.tag.view.search</field>
        <field name="model">srm.tag</field>
        <field name="arch" type="xml">
            <search string="Search Tags">
                <field name="name" string="Name" />
                <field name="display_name" string="Tag" />
                <separator />
                <filter name="inactive" string="Archived" domain="[('active', '=', False)]" />
                <group>
                    <filter name="group_parent_id" string="Parent Tag"
                        context="{'group_by': 'parent_id'}" />
                    <filter name="group_color" string="Color"
                        context="{'group_by': 'color'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="srm_tag_view_list" model="ir.ui.view">
        <field name="name">srm.tag.view.list</field>
        <field name="model">srm.tag</field>
        <field name="arch" type="xml">
            <list string="Tags" editable="bottom" multi_edit="1" sample="1">
                <field name="name" />
                <field name="parent_id" string="Parent Tag" domain="[('id', '!=', id)]" />
                <field name="color" widget="color_picker" />
            </list>
        </field>
    </record>

    <record id="srm_tag_action" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">srm.tag</field>
        <field name="search_view_id" ref="srm_tag_view_search" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create SRM Tags
            </p><p>
                Use Tags to classify and track your purchase orders
                (supplier type, product family, ...). Tags can be nested
                to build a hierarchy.
            </p>
        </field>
    </record>

</odoo>
