<?xml version="1.0"?>
<odoo>
    <!--
        survey.tag views
    -->
    <record id="survey_tag_view_form" model="ir.ui.view">
        <field name="name">survey.tag.view.form</field>
        <field name="model">survey.tag</field>
        <field name="arch" type="xml">
            <form string="Tags">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Human Resources"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="color" required="True" widget="color_picker"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="survey_tag_view_tree" model="ir.ui.view">
        <field name="name">survey.tag.view.list</field>
        <field name="model">survey.tag</field>
        <field name="arch" type="xml">
            <list string="Tags" editable="bottom" sample="1">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <!-- Tags Configuration -->
    <record id="survey_tag_action" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">survey.tag</field>
        <field name="view_id" ref="survey_tag_view_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
            Create Survey Tags
            </p><p>
            Use tags to categorize and filter your surveys.
            </p>
        </field>
    </record>
</odoo>
