<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="survey_category_view_list" model="ir.ui.view">
        <field name="name">survey.category.view.list</field>
        <field name="model">survey.category</field>
        <field name="arch" type="xml">
            <list string="Categories" editable="bottom">
                <field name="sequence" widget="handle" />
                <field name="name" />
                <field name="color" widget="color_picker" optional="hide" />
                <field name="survey_count" string="Surveys" />
            </list>
        </field>
    </record>

    <record id="survey_category_view_form" model="ir.ui.view">
        <field name="name">survey.category.view.form</field>
        <field name="model">survey.category</field>
        <field name="arch" type="xml">
            <form string="Category">
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="sequence" />
                        <field name="color" widget="color_picker" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_survey_category" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="path">survey-categories</field>
        <field name="res_model">survey.category</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new category
            </p>
        </field>
    </record>


</odoo>