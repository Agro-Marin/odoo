<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="web.IframeWrapperField">
        <div class="o_preview_iframe_wrapper">
            <!--
                sandbox="allow-same-origin" (deliberately WITHOUT allow-scripts):
                the field value is written verbatim into the iframe document, so
                any <script> in it must NOT execute with the session. Same-origin
                is kept so the parent can still write into contentDocument and the
                server-rendered layout preview (base_document_layout, script-free)
                keeps working.
            -->
            <iframe src="about:blank" class="o_preview_iframe" t-ref="iframe" sandbox="allow-same-origin"/>
        </div>
    </t>

</templates>
