<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="web.OverlayContainer">
        <div class="o-overlay-container" t-ref="this.root">
            <t t-foreach="this.sortedOverlays()" t-as="overlay" t-key="overlay.id">
                <ErrorHandler t-if="this.isVisible(overlay)" onError="(error) => this.handleError(overlay, error)">
                    <OverlayItem scope="overlay.scope" component="overlay.component" props="overlay.props"/>
                </ErrorHandler>
            </t>
        </div>
    </t>

    <t t-name="web.OverlayContainer.Item">
        <div t-ref="this.rootRef" class="o-overlay-item">
            <t t-component="this.componentClass" t-props="this.componentProps" />
        </div>
    </t>

</templates>
