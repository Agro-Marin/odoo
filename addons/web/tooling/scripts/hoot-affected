#!/bin/sh
''':'
# Self-locating trampoline (sh/python polyglot): re-exec this file with the
# workspace venv interpreter so no venv path is ever hardcoded. The workspace
# root is 6 levels up (<ws>/addons/odoo/addons/web/tooling/scripts). Override
# with $ODOO_VENV_PYTHON when the workspace holds several venvs.
# NB: no `set --` in here — it would clobber "$@" (the real CLI arguments).
here="$(cd "$(dirname "$0")" && pwd)"
ws="$(cd "$here/../../../../../.." && pwd)"
py="${ODOO_VENV_PYTHON:-}"
if [ -z "$py" ]; then
    for cand in "$ws"/venv/*/bin/python; do
        [ -x "$cand" ] || continue
        if [ -n "$py" ]; then
        echo "$(basename "$0"): several venvs under $ws/venv; set ODOO_VENV_PYTHON" >&2
            exit 1
        fi
        py="$cand"
    done
    if [ -z "$py" ]; then
        echo "$(basename "$0"): no venv python under $ws/venv; set ODOO_VENV_PYTHON" >&2
        exit 1
    fi
fi
exec "$py" "$0" "$@"
'''
"""Print the minimal set of @web/... HOOT suites affected by changed JS files.

With no arguments, uses ``git diff --name-only HEAD`` inside addons/odoo and
keeps files under an addon ``static/`` tree. Otherwise treats each argument as a
changed file path.

Uses a conservative import-scan of the fork's ESM specifiers (direct importers
of the changed module, plus one hop through src files). Feed the output to the
runner, or just run ``hoot --affected`` which does the same selection.

Examples
--------
  hoot-affected
  hoot-affected addons/web/static/src/core/domain.js
  hoot --affected      # run them
"""


# CLI tool: print() is the user-facing output channel.
# ruff: noqa: T201
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
import hoot_lib as H


def main() -> int:
    args = [a for a in sys.argv[1:] if not a.startswith("-")]
    changed = H.changed_web_js(args or None)
    if not changed:
        print("# no changed JS files under a static/ tree", file=sys.stderr)
        return 0
    suites = H.affected_suites(changed)
    if not suites:
        print("# no affected suites detected", file=sys.stderr)
        return 0
    for suite in suites:
        print(suite)
    return 0


if __name__ == "__main__":
    sys.exit(main())
