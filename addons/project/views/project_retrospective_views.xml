<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Search -->
    <record id="project_retrospective_search" model="ir.ui.view">
        <field name="name">project.retrospective.search</field>
        <field name="model">project.retrospective</field>
        <field name="arch" type="xml">
            <search string="Retrospectives">
                <field name="name"/>
                <field name="project_id"/>
                <field name="facilitator_id"/>
                <separator/>
                <filter string="Has Open Actions" name="open_actions" domain="[('action_ids.state', 'in', ['open', 'in_progress'])]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Done" name="done" domain="[('state', '=', 'done')]"/>
                <group>
                    <filter string="Project" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date:month'}"/>
                    <filter string="Facilitator" name="group_facilitator" context="{'group_by': 'facilitator_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Form -->
    <record id="project_retrospective_form" model="ir.ui.view">
        <field name="name">project.retrospective.form</field>
        <field name="model">project.retrospective</field>
        <field name="arch" type="xml">
            <form string="Retrospective">
                <header>
                    <button string="Carry Forward Actions" name="action_carry_forward" type="object"
                        invisible="not previous_id or state == 'done'" class="oe_highlight"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" placeholder="e.g. Sprint 5 Retro"/>
                            <field name="project_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="facilitator_id" widget="many2one_avatar_user"/>
                            <field name="previous_id" domain="[('project_id', '=', project_id)]"/>
                            <field name="open_action_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="What Went Well" name="went_well">
                            <field name="went_well" placeholder="Practices and decisions worth repeating..."/>
                        </page>
                        <page string="What Needs Improvement" name="to_improve">
                            <field name="to_improve" placeholder="Areas where changes would improve outcomes..."/>
                        </page>
                        <page string="Action Items" name="actions">
                            <field name="action_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="owner_id" widget="many2one_avatar_user"/>
                                    <field name="category" optional="show"/>
                                    <field name="due_date"/>
                                    <field name="state"/>
                                    <field name="carried_from_id" optional="hide"/>
                                    <field name="resolution_note" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- List -->
    <record id="project_retrospective_list" model="ir.ui.view">
        <field name="name">project.retrospective.list</field>
        <field name="model">project.retrospective</field>
        <field name="arch" type="xml">
            <list string="Retrospectives" default_order="date desc">
                <field name="date"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="facilitator_id" widget="many2one_avatar_user"/>
                <field name="action_count"/>
                <field name="open_action_count" decoration-danger="open_action_count > 0"/>
                <field name="state" widget="badge"
                    decoration-info="state == 'draft'"
                    decoration-success="state == 'done'"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_project_retrospective" model="ir.actions.act_window">
        <field name="name">Retrospectives</field>
        <field name="res_model">project.retrospective</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="project_retrospective_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No retrospectives yet
            </p>
            <p>
                Run regular retrospectives to capture lessons learned and
                track improvement actions.
            </p>
        </field>
    </record>

    <!-- Action from project smart button -->
    <record id="action_project_retrospective_from_project" model="ir.actions.act_window">
        <field name="name">Retrospectives</field>
        <field name="res_model">project.retrospective</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="project_retrospective_search"/>
        <field name="context">{'default_project_id': active_id}</field>
        <field name="domain">[('project_id', '=', active_id)]</field>
    </record>

    <!-- Open Actions across all retrospectives -->
    <record id="project_retrospective_action_search" model="ir.ui.view">
        <field name="name">project.retrospective.action.search</field>
        <field name="model">project.retrospective.action</field>
        <field name="arch" type="xml">
            <search string="Retrospective Actions">
                <field name="name"/>
                <field name="project_id"/>
                <field name="owner_id"/>
                <separator/>
                <filter string="Open" name="open" domain="[('state', 'in', ['open', 'in_progress'])]"/>
                <filter string="My Actions" name="my_actions" domain="[('owner_id', '=', uid)]"/>
                <group>
                    <filter string="Project" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Category" name="group_category" context="{'group_by': 'category'}"/>
                    <filter string="Owner" name="group_owner" context="{'group_by': 'owner_id'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="project_retrospective_action_list" model="ir.ui.view">
        <field name="name">project.retrospective.action.list</field>
        <field name="model">project.retrospective.action</field>
        <field name="arch" type="xml">
            <list string="Retrospective Actions" editable="bottom">
                <field name="name"/>
                <field name="project_id"/>
                <field name="retrospective_id"/>
                <field name="owner_id" widget="many2one_avatar_user"/>
                <field name="category" optional="show"/>
                <field name="due_date"/>
                <field name="state"/>
                <field name="resolution_note" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="action_project_retrospective_actions" model="ir.actions.act_window">
        <field name="name">Retrospective Actions</field>
        <field name="res_model">project.retrospective.action</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="project_retrospective_action_search"/>
        <field name="context">{'search_default_open': 1, 'search_default_group_category': 1, 'search_default_group_project': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No open retrospective actions
            </p>
        </field>
    </record>

</odoo>
