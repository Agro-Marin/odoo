<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Portfolio list: all projects with key metrics -->
    <record id="project_portfolio_list" model="ir.ui.view">
        <field name="name">project.project.portfolio.list</field>
        <field name="model">project.project</field>
        <field name="arch" type="xml">
            <list string="Portfolio" default_order="health_score asc, name">
                <field name="name" class="fw-bold"/>
                <field name="user_id" string="PM" widget="many2one_avatar_user"/>
                <field name="health_score"/>
                <field name="health_status" widget="badge"
                    decoration-success="health_status == 'healthy'"
                    decoration-info="health_status == 'attention'"
                    decoration-warning="health_status == 'warning'"
                    decoration-danger="health_status == 'critical'"/>
                <field name="last_update_status" string="Status" widget="project_state_selection"/>
                <field name="task_completion_percentage" widget="progressbar" string="Progress"/>
                <field name="wip_count" string="WIP"/>
                <field name="throughput_week" string="Tasks/wk" optional="show"/>
                <field name="avg_lead_time" widget="float_time" string="Lead Time" optional="show"/>
                <field name="avg_cycle_time" widget="float_time" string="Cycle Time" optional="show"/>
                <field name="risk_count" string="Risks" optional="show"/>
                <field name="deadline_compliance_pct" widget="percentage" string="DL Compliance" optional="show"/>
                <field name="date_start" string="Start" optional="hide"/>
                <field name="date" string="End" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Portfolio search with health filters -->
    <record id="project_portfolio_search" model="ir.ui.view">
        <field name="name">project.project.portfolio.search</field>
        <field name="model">project.project</field>
        <field name="arch" type="xml">
            <search string="Portfolio">
                <field name="name"/>
                <field name="user_id"/>
                <field name="tag_ids"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Not Templates" name="not_templates" domain="[('is_template', '=', False)]"/>
                <filter string="At Risk or Worse" name="at_risk" domain="[('last_update_status', 'in', ['at_risk', 'off_track'])]"/>
                <filter string="Has Risks" name="has_risks" domain="[('risk_ids', '!=', False)]"/>
                <filter string="Strategic" name="strategic" domain="[('tag_ids.is_strategic', '=', True)]"/>
                <group>
                    <filter string="Status" name="group_status" context="{'group_by': 'last_update_status'}"/>
                    <filter string="Project Manager" name="group_pm" context="{'group_by': 'user_id'}"/>
                    <filter string="Phase" name="group_phase" context="{'group_by': 'phase_id'}"/>
                    <filter string="Strategic Objective" name="group_strategic" context="{'group_by': 'tag_ids'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Portfolio graph: health score by project, grouped by phase -->
    <record id="project_portfolio_graph" model="ir.ui.view">
        <field name="name">project.project.portfolio.graph</field>
        <field name="model">project.project</field>
        <field name="arch" type="xml">
            <graph string="Portfolio" sample="1">
                <field name="name"/>
                <field name="health_score" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Portfolio pivot: flow metrics by project and phase -->
    <record id="project_portfolio_pivot" model="ir.ui.view">
        <field name="name">project.project.portfolio.pivot</field>
        <field name="model">project.project</field>
        <field name="arch" type="xml">
            <pivot string="Portfolio" sample="1">
                <field name="name" type="row"/>
                <field name="phase_id" type="col"/>
                <field name="wip_count" type="measure"/>
                <field name="throughput_week" type="measure"/>
                <field name="avg_cycle_time" type="measure"/>
                <field name="avg_lead_time" type="measure"/>
                <field name="deadline_compliance_pct" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Portfolio action -->
    <record id="action_project_portfolio" model="ir.actions.act_window">
        <field name="name">Portfolio Dashboard</field>
        <field name="res_model">project.project</field>
        <field name="view_mode">list,graph,pivot,kanban</field>
        <field name="view_id" ref="project_portfolio_list"/>
        <field name="search_view_id" ref="project_portfolio_search"/>
        <field name="domain">[('is_template', '=', False)]</field>
        <field name="context">{'search_default_active': 1, 'search_default_not_templates': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No projects in the portfolio
            </p>
            <p>
                The portfolio dashboard shows all active projects with
                health scores, flow metrics, and risk indicators at a glance.
            </p>
        </field>
    </record>

</odoo>
