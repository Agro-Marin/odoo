<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="project_baseline_form" model="ir.ui.view">
        <field name="name">project.baseline.form</field>
        <field name="model">project.baseline</field>
        <field name="arch" type="xml">
            <form string="Baseline">
                <header>
                    <button string="Capture Snapshot" name="action_capture_snapshot" type="object"
                        class="oe_highlight" invisible="line_ids"/>
                    <button string="Set as Current" name="action_set_current" type="object"
                        invisible="is_current"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-tasks" disabled="1">
                            <field name="line_count" string="Tasks" widget="statinfo"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Current" bg_color="text-bg-success" invisible="not is_current"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="project_id"/>
                        </group>
                        <group>
                            <field name="date_created"/>
                            <field name="created_by_id" widget="many2one_avatar_user"/>
                            <field name="is_current"/>
                        </group>
                    </group>
                    <field name="line_ids">
                        <list string="Baseline Tasks" editable="bottom">
                            <field name="task_name"/>
                            <field name="task_id" optional="show"/>
                            <field name="planned_start" optional="show"/>
                            <field name="planned_end"/>
                            <field name="planned_hours" widget="float_time"/>
                            <field name="milestone_id" optional="hide"/>
                            <field name="step_id" optional="hide"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="project_baseline_list" model="ir.ui.view">
        <field name="name">project.baseline.list</field>
        <field name="model">project.baseline</field>
        <field name="arch" type="xml">
            <list string="Baselines">
                <field name="name"/>
                <field name="project_id"/>
                <field name="date_created"/>
                <field name="created_by_id" widget="many2one_avatar_user"/>
                <field name="line_count"/>
                <field name="is_current" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_project_baseline_from_project" model="ir.actions.act_window">
        <field name="name">Baselines</field>
        <field name="res_model">project.baseline</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'default_project_id': active_id}</field>
        <field name="domain">[('project_id', '=', active_id)]</field>
    </record>

</odoo>
