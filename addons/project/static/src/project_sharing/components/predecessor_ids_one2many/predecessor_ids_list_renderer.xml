<templates>
    <t t-name="project.PredecessorIdsListRowsRenderer" t-inherit="web.ListRenderer.Rows" t-inherit-mode="primary" owl="1">
        <xpath expr="//t[@t-foreach='list.records']" position="after">
        <tr t-if="nbHiddenRecords" class="o_data_row">
            <td t-att-colspan="nbCols" class="text-center">
                <i class="text-muted">
                    This task is currently blocked by <t t-out="nbHiddenRecords"/> (other) tasks to which you do not have access.
                </i>
            </td>
        </tr>
        </xpath>
    </t>
</templates>
