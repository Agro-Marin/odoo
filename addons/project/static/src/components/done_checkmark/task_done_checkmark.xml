<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="project.TaskCheckMark" t-inherit="web.BooleanToggleField" t-inherit-mode="primary">
        <xpath expr="//CheckBox" position="replace">
            <button type="button"
               title="Mark as done"
               aria-label="Mark as done"
               t-att-aria-pressed="isReached ? 'true' : 'false'"
               t-att-disabled="props.readonly"
               t-on-click.stop="onToggle"
               t-attf-class="btn p-0 border-0 o_todo_done_button fa-lg {{!isReached ? 'fa-regular fa-circle-check' : 'fa-solid fa-circle-check done_button_enabled'}}"/>
        </xpath>
    </t>

</templates>
